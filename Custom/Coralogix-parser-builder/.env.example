# Coralogix Parser Builder - API configuration
# Copy to .env and fill in your values, or export in shell
#
# Required for: cli.py deploy, deploy_mgmt_api.py, deploy_linux_parsers.py
# API key must have PARSINGRULES role (Settings → API Keys)

CORALOGIX_API_KEY=your-personal-api-key-with-parsingrules-role
CORALOGIX_ENDPOINT=eu1.coralogix.com

# Region examples:
#   EU1:  eu1.coralogix.com
#   US2:  cx498.coralogix.com
#   US1:  coralogix.us
#   AP1:  coralogix.in
